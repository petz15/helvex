hcloud_token = "replace-me"
project_name = "helvex"
location     = "fsn1"

# NOTE: do NOT use 10.42.0.0/16 or 10.43.0.0/16 — those are K3s's default
# pod/service CIDRs and will cause routing conflicts on the node network.
# network_cidr = "10.0.0.0/16"   # default, change only if you need a different range
# subnet_cidr  = "10.0.1.0/24"

admin_cidrs = [
  "203.0.113.10/32"  # replace with your actual IP
]

# These must match names of keys already uploaded in Hetzner Cloud.
ssh_keys = [
  "my-main-key"
]

# lb_type = "lb11"  # default — cheapest Hetzner LB (~€6/month)

# Generate with: openssl rand -hex 32
k3s_token = "replace-with-openssl-rand-hex-32-output"
