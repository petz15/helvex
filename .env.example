# PostgreSQL connection — set individual fields (recommended)
POSTGRES_HOST=192.168.1.100
POSTGRES_PORT=5432
POSTGRES_USER=zefix
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=zefix_analyzer

# Alternatively, set the full URL directly (overrides the fields above)
# DATABASE_URL=postgresql://zefix:password@192.168.1.100:5432/zefix_analyzer

# Zefix API
ZEFIX_API_BASE_URL=https://www.zefix.admin.ch/ZefixREST/api/v1
# Optional: set if your Zefix account requires HTTP Basic Auth
ZEFIX_API_USERNAME=
ZEFIX_API_PASSWORD=

# Google Custom Search API
# Set to false to disable Google Search entirely and use Zefix data only
GOOGLE_SEARCH_ENABLED=true
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here
# Daily search quota (free tier = 100; paid tier can be higher)
GOOGLE_DAILY_QUOTA=100
